{
  "title": "AI & RAG Intelligence",
  "uid": "ai-rag-intel",
  "tags": ["AI", "RAG", "Legal"],
  "timezone": "browser",
  "schemaVersion": 36,
  "panels": [
    {
      "title": "AI Request Volume",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [{ "expr": "sum(rate(ai_llm_calls_total[5m])) by (model)" }]
    },
    {
      "title": "LLM Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(ai_llm_latency_seconds_bucket[5m])) by (le, model))" }]
    },
    {
      "title": "Cumulative AI Cost (USD)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [{ "expr": "sum(ai_cost_usd_total)" }],
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "title": "Mean Grounding Score",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [{ "expr": "avg(ai_evaluation_score_sum{metric='grounding'} / ai_evaluation_score_count{metric='grounding'})" }],
      "fieldConfig": { "defaults": { "min": 0, "max": 1, "thresholds": { "steps": [{ "color": "red", "value": 0 }, { "color": "yellow", "value": 0.6 }, { "color": "green", "value": 0.85 }] } } }
    },
    {
      "title": "Hallucination Detection Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [{ "expr": "sum(rate(ai_hallucinations_total{status='detected'}[1h])) / sum(rate(ai_llm_calls_total[1h]))" }]
    },
    {
      "title": "Retrieval Performance by Strategy",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [{ "expr": "sum(rate(ai_retrieval_latency_seconds_sum[5m])) by (strategy) / sum(rate(ai_retrieval_latency_seconds_count[5m])) by (strategy)" }]
    }
  ]
}
